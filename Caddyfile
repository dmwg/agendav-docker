# ──────────────────────────────────────────────────────────────────────────────
# Caddyfile for AgenDAV served at a subdirectory (default: /view)
#
# Caddy sits behind an upstream reverse proxy that terminates TLS.
# It handles:
#   - stripping the path prefix before passing requests to PHP-FPM
#   - trusting X-Forwarded-* headers from the upstream proxy
#   - serving AgenDAV's static assets directly (bypass PHP-FPM)
# ──────────────────────────────────────────────────────────────────────────────

{
    admin off
    auto_https off
    debug

    # trusted_proxies is a global option — it cannot appear inside a site block.
    # This tells Caddy to trust X-Forwarded-* headers from these source IPs.
    # Restrict to your actual upstream IP/subnet in production.
    servers {
        trusted_proxies static private_ranges
    }
}

:8080 {

    # ── Redirect /view → /view/ ─────────────────────────────────────────────────
    redir /view /view/ permanent

    # Strip /view from the URI up front, before any routing logic.
    # This runs for all /view/* requests unconditionally.
    uri /view/* strip_prefix /view

    # Now all /view/* requests have been rewritten to /* internally.
    # root is set globally so both file_server and reverse_proxy see it.
    root * /var/www/agendav/web/public

    route {
        # Serve real files from disk directly.
        # pass_thru falls through to reverse_proxy when file not found.
        file_server {
            pass_thru
        }

        # All other requests go to PHP-FPM.
        # SCRIPT_NAME uses /view/index.php so Symfony computes the base path
        # correctly: REQUEST_URI /view/login minus base /view = route /login.
        reverse_proxy unix//run/php-fpm.sock {
            transport fastcgi {
                root /var/www/agendav/web/public
                split .php
                env SCRIPT_FILENAME /var/www/agendav/web/public/index.php
                env SCRIPT_NAME     /view/index.php
                env HTTPS           on
            }
        }
    }

    # ── Health-check ──────────────────────────────────────────────────────────
    respond /healthz 200

    # ── Anything else → 404 ───────────────────────────────────────────────────
    handle {
        respond "Not found - path: {http.request.uri}" 404
    }
}
